{
  "name": "downdoc",
  "version": "1.0.2-stable",
  "description": "Rapidly down-converts AsciiDoc to Markdown. Often used to prepare an AsciiDoc README for npm packaging.",
  "license": "MIT",
  "author": "Dan Allen",
  "contributors": [
    "Dan Allen <dan@opendevise.com>"
  ],
  "repository": "https://github.com/opendevise/downdoc",
  "bugs": {
    "url": "https://github.com/opendevise/downdoc/issues"
  },
  "engines": {
    "node": ">=16.17.0"
  },
  "scripts": {
    "build": "npm test",
    "postbuild": "npm run lint",
    "coverage": "nyc _mocha",
    "format": "npx -y --include optional @biomejs/biome@~2.1 format --write",
    "postformat": "node --disable-warning ExperimentalWarning npm/postformat.js",
    "lint": "npx -y --include optional @biomejs/biome@~2.1 lint --error-on-warnings",
    "postpublish": "downdoc --postpublish",
    "prepublishOnly": "downdoc --prepublish",
    "test": "_mocha",
    "pretidy": "npm run lint",
    "tidy": "npm run format",
    "version": "node npm/version.js"
  },
  "bin": {
    "downdoc": "bin/downdoc"
  },
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "imports": {
    "#cli": "./lib/cli.js"
  },
  "files": [
    "lib"
  ],
  "workspaces": [
    "."
  ],
  "keywords": [
    "asciidoc",
    "markdown",
    "converter"
  ],
  "devDependencies": {
    "chai": "~4.3",
    "chai-fs": "~2.0",
    "chai-string": "~1.5",
    "dirty-chai": "~2.0",
    "mocha": "~10.2",
    "nyc": "~15.1"
  },
  "nyc": {
    "all": true,
    "branches": 100,
    "cacheDir": "node_modules/.cache/nyc",
    "checkCoverage": true,
    "include": [
      "lib/**/*.js"
    ],
    "lines": 100,
    "reporter": [
      "cobertura",
      "lcov",
      "text"
    ],
    "reportDir": "reports"
  }
}
